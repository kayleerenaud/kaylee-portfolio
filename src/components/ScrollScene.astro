---
// SCROLL-LOCK HERO — a pinned stage whose layers scrub in lockstep with the
// scroll wheel (the course101 effect). Nothing here uses a CSS transition:
// every transform is driven directly by --p (0 → 1 = scroll progress through the
// scene). Because it is position-driven, it moves exactly at the speed of the
// scroll and reverses the instant you scroll back up. No dissolve, no lag.
//
// The colored bands are placeholders for parallax image layers — swap them for
// real artwork later (each .layer can become a background-image).
import { site } from '../config/site';
---
<section class="scene" data-scene aria-label="Intro">
  <div class="scene-sticky">
    <div class="layer sky" data-depth="0.12"></div>
    <div class="layer mid" data-depth="0.34"></div>
    <div class="layer fore" data-depth="0.62"></div>

    <div class="scene-copy">
      <p class="kicker">Portfolio</p>
      <h1>{site.brand}</h1>
      <p class="lede">{site.tagline}</p>
    </div>

    <div class="scene-hint" aria-hidden="true"><span>scroll</span><i></i></div>
  </div>
</section>

<style>
  /* tall track that the sticky stage scrubs through */
  .scene { position: relative; height: 240vh; }
  .scene-sticky {
    position: sticky; top: 0; height: 100vh; overflow: hidden;
    display: grid; place-items: center;
    /* --p is written by JS each frame: 0 at scene top, 1 at scene bottom */
    --p: 0;
  }

  .layer { position: absolute; inset: -10% -2%; will-change: transform; }
  /* placeholder parallax bands in the section's accent — replace with imagery */
  .sky  { background: radial-gradient(120% 90% at 50% 8%, color-mix(in srgb, var(--accent) 26%, var(--bg)), var(--bg) 70%); }
  .mid  { background: radial-gradient(90% 70% at 70% 100%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 60%); }
  .fore { background: linear-gradient(0deg, color-mix(in srgb, var(--accent) 30%, var(--bg)) 0%, transparent 38%); }

  /* parallax: each layer rises at its own rate, locked to --p */
  .sky  { transform: translate3d(0, calc(var(--p) * -6%),  0) scale(1.05); }
  .mid  { transform: translate3d(0, calc(var(--p) * -16%), 0); }
  .fore { transform: translate3d(0, calc(var(--p) * -30%), 0); }

  .scene-copy {
    position: relative; z-index: 2; text-align: center; padding: 0 var(--gap);
    /* headline drifts up and eases out as you scroll through the lock */
    transform: translate3d(0, calc(var(--p) * -12vh), 0);
    opacity: calc(1 - var(--p) * 1.15);
  }
  .scene-copy .kicker { font-size: 0.85rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin: 0 0 0.6rem; }
  .scene-copy h1 { font-size: clamp(2.6rem, 9vw, 6rem); margin: 0; line-height: 0.98; }
  .scene-copy .lede { font-size: clamp(1.05rem, 2.4vw, 1.4rem); color: var(--ink-soft); margin: 1rem auto 0; max-width: 44ch; }

  .scene-hint {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem; z-index: 2;
    color: var(--ink-soft); font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
    opacity: calc(1 - var(--p) * 3); /* fades fast as the lock begins */
  }
  .scene-hint i { width: 1px; height: 34px; background: linear-gradient(var(--accent), transparent); }

  @media (prefers-reduced-motion: reduce) {
    /* no scrub: collapse to a normal one-screen hero */
    .scene { height: auto; }
    .scene-sticky { position: static; height: auto; min-height: 78vh; }
    .layer, .scene-copy { transform: none !important; opacity: 1 !important; }
    .scene-hint { display: none; }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const scene = document.querySelector('[data-scene]') as HTMLElement | null;
  const stage = scene?.querySelector('.scene-sticky') as HTMLElement | null;
  if (scene && stage && !reduce) {
    let ticking = false;
    const update = () => {
      ticking = false;
      const rect = scene.getBoundingClientRect();
      const total = scene.offsetHeight - window.innerHeight;
      // how far we've scrolled INTO the scene, clamped 0..1
      const p = total > 0 ? Math.min(1, Math.max(0, -rect.top / total)) : 0;
      stage.style.setProperty('--p', p.toFixed(4));
    };
    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
</script>
