---
// A little PILE of photos, each tilted at its own angle. On load it "deals"
// through the stack — each frame pops to the top in turn (same rate as before) —
// and lands with the professional shot on top. Hover (or tab to it) to reshuffle.
// Before JS / with reduced-motion it simply rests with the pro shot on top.
const { frames, alt = 'Portrait of Kaylee Renaud' } = Astro.props as { frames: string[]; alt?: string };
const last = frames.length - 1;
// per-photo tilt + tiny offset so the pile looks hand-stacked
const rot = [-5, 4.5, -3.5, 2.5, -2, 3.5];
const dx  = [-7, 6, -4, 5, -6, 4];
const dy  = [5, -4, 6, -3, -5, 4];
---
<figure class="headshot" data-headshot tabindex="0" aria-label={alt}>
  <div class="hs-stack">
    {frames.map((src, i) => (
      <img
        src={src}
        alt={i === last ? alt : ''}
        class:list={['hs-frame', i === 0 && 'on']}
        data-i={i}
        style={`--rot:${rot[i % rot.length]}deg; --tx:${dx[i % dx.length]}px; --ty:${dy[i % dy.length]}px;`}
        loading="eager"
        decoding="async"
        aria-hidden={i === last ? undefined : 'true'}
      />
    ))}
  </div>
  <figcaption class="hs-tag" aria-hidden="true">{`1 / ${frames.length}`}</figcaption>
</figure>

<style>
  .headshot { margin: 0; width: min(78vw, 350px); position: relative; outline: none; }
  .hs-stack { position: relative; aspect-ratio: 4 / 5; }
  .hs-frame {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    /* bias the crop up toward the face (portraits are shot with headroom, so a
       centered crop lands on the torso) */
    object-position: center 30%;
    border: 7px solid #f4efe5; border-radius: 3px; background: #f4efe5;
    box-shadow: 0 10px 26px rgba(0,0,0,.45);
    transform: rotate(var(--rot)) translate(var(--tx), var(--ty));
    transition: transform .22s ease, box-shadow .22s ease;
    z-index: 1;
  }
  /* the frame currently on top: pulled forward, straightened a touch, lifted */
  .hs-frame.on {
    z-index: 5;
    transform: rotate(calc(var(--rot) * .45)) translate(calc(var(--tx) * .5), calc(var(--ty) * .5)) scale(1.015);
    box-shadow: 0 18px 40px rgba(0,0,0,.5);
  }
  .hs-tag {
    position: absolute; right: -6px; bottom: -16px; z-index: 6;
    font-family: var(--font-mono); font-size: .72rem; letter-spacing: .12em;
    color: var(--accent); background: var(--bg); padding: 2px 8px; border-radius: 3px;
    border: 1px solid var(--line);
  }
  @media (prefers-reduced-motion: reduce) { .hs-frame { transition: none; } }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.querySelectorAll<HTMLElement>('[data-headshot]').forEach((box) => {
    const frames = Array.from(box.querySelectorAll<HTMLElement>('.hs-frame'));
    if (frames.length < 2) return;
    const last = frames.length - 1;
    const tag = box.querySelector<HTMLElement>('.hs-tag');
    let timer = 0;
    const show = (i: number) => {
      frames.forEach((f, k) => f.classList.toggle('on', k === i));
      if (tag) tag.textContent = `${i + 1} / ${frames.length}`;
    };
    const play = () => {
      if (reduce) { show(last); return; }
      window.clearInterval(timer);
      let i = 0; show(0);
      timer = window.setInterval(() => {
        i++;
        if (i >= frames.length) { window.clearInterval(timer); show(last); return; }
        show(i);
      }, 230);
    };
    if (reduce) show(last);            // reduced-motion: rest on the pro shot
    else setTimeout(play, 450);        // otherwise flip from the first candid up to it
    box.addEventListener('mouseenter', play);
    box.addEventListener('focus', play);
  });
</script>
