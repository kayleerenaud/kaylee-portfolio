---
// Pencil-textured single-line doodle that "draws itself" bound to scroll
// position (inks in as it enters the viewport, un-inks as you scroll back —
// at the speed of the scroll, no timed dissolve). After it's drawn it settles
// into a gentle idle float. The pencil wobble/grain comes from the #kr-pencil
// SVG filter, which About renders once.
//
// These are placeholder doodles — swap in Kaylee's own line art anytime.
const LIB: Record<string, { vb: string; d: string[] }> = {
  star:   { vb: '0 0 100 100', d: ['M50 14 L60 40 L88 41 L66 59 L74 87 L50 71 L26 87 L34 59 L12 41 L40 40 Z'] },
  heart:  { vb: '0 0 100 100', d: ['M50 80 C24 60 26 30 44 30 C50 30 50 38 50 42 C50 38 50 30 56 30 C74 30 76 60 50 80 Z'] },
  wave:   { vb: '0 0 112 80',  d: ['M8 50 Q20 34 32 50 T56 50 T80 50 T104 50'] },
  spark:  { vb: '0 0 100 100', d: ['M50 26 V74', 'M26 50 H74', 'M33 33 L67 67', 'M67 33 L33 67'] },
  arrow:  { vb: '0 0 100 100', d: ['M12 46 C38 22 62 72 86 44', 'M86 44 L74 43', 'M86 44 L80 55'] },
  pin:    { vb: '0 0 100 100', d: ['M50 86 C30 60 32 38 50 30 C68 38 70 60 50 86 Z', 'M50 50 m-7 0 a7 7 0 1 0 14 0 a7 7 0 1 0 -14 0'] },
  clapper:{ vb: '0 0 100 100', d: ['M16 54 H82 V82 H16 Z', 'M16 54 L19 42 L86 50 L83 62 Z', 'M30 44 L26 56', 'M46 46 L42 58', 'M62 48 L58 60'] },
  thread: { vb: '0 0 100 100', d: ['M22 34 L66 72', 'M22 34 q-6 -3 -3 -8 q4 -4 8 0', 'M66 72 q14 -5 8 -16 q-6 -9 5 -15'] },
  quill:  { vb: '0 0 100 100', d: ['M28 80 C40 60 58 36 80 22', 'M52 46 q9 -3 13 -11', 'M44 56 q9 -3 13 -11', 'M60 38 q9 -3 13 -11', 'M28 80 L23 86 L32 84 Z'] },
  squiggle:{ vb:'0 0 120 60',  d: ['M8 40 C20 10 34 10 44 34 C52 52 66 52 72 30 C78 10 96 12 112 38'] },
  // laurel wreath — Awards
  laurel: { vb: '0 0 100 100', d: [
    'M50 88 C36 80 26 60 30 36', 'M50 88 C64 80 74 60 70 36',
    'M38 72 q-9 -4 -10 -13', 'M34 58 q-9 -4 -10 -13', 'M32 45 q-9 -4 -9 -13',
    'M62 72 q9 -4 10 -13', 'M66 58 q9 -4 10 -13', 'M68 45 q9 -4 9 -13',
  ] },
  // graduation cap — Education
  gradcap: { vb: '0 0 100 100', d: [
    'M50 34 L85 49 L50 64 L15 49 Z',
    'M33 55 L33 69 Q50 79 67 69 L67 55',
    'M67 51 L75 51 L75 71', 'M75 71 l-3.5 7 l7 0 z',
  ] },
  // a summit with a flag — Experience (milestones climbed)
  summit: { vb: '0 0 100 100', d: [
    'M12 82 L38 40 L52 60 L64 44 L88 82 Z',
    'M64 44 L64 28', 'M64 28 L80 33 L64 38',
  ] },
  // open book — prose
  book: { vb: '0 0 100 100', d: [
    'M50 34 C40 26 22 26 14 30 L14 72 C22 68 40 68 50 76',
    'M50 34 C60 26 78 26 86 30 L86 72 C78 68 60 68 50 76',
    'M50 34 L50 76',
  ] },
  // retro tv — pilot
  tv: { vb: '0 0 100 100', d: [
    'M20 42 H80 V82 H20 Z', 'M28 50 H60 V74 H28 Z',
    'M68 52 v6', 'M68 64 v6', 'M40 42 L30 26', 'M60 42 L72 26',
  ] },
  // hanging spotlight — stage
  spotlight: { vb: '0 0 100 100', d: [
    'M50 10 L50 20', 'M40 20 H60 L55 30 H45 Z',
    'M45 30 L28 78', 'M55 30 L72 78', 'M28 78 H72',
  ] },
  // dress form / tailor's mannequin — Costume (hourglass body, neck, tripod foot)
  mannequin: { vb: '0 0 100 100', d: [
    'M50 28 C44 28 39 30 36 36 C32 43 40 49 42 55 C43 61 36 62 37 67 C38 73 45 78 50 78 C55 78 62 73 63 67 C64 62 57 61 58 55 C60 49 68 43 64 36 C61 30 56 28 50 28 Z',
    'M46 28 C45 22 46 18 50 18 C54 18 55 22 54 28',  // neck
    'M43 31 Q50 36 57 31',                            // neckline
    'M50 78 L50 87',                                  // stand pole
    'M50 87 L40 96', 'M50 87 L60 96', 'M50 87 L50 96',// tripod foot
  ] },
  // comedy + tragedy theater masks — stage / performance
  mask: { vb: '0 0 100 100', d: [
    // comedy mask (left)
    'M26 32 Q40 28 53 31 C52 44 51 56 45 64 C41 70 38 72 38 72 C38 72 34 69 31 63 C26 55 26 43 26 32 Z',
    'M31 42 Q35 38 39 42', 'M42 42 Q46 38 50 42',     // smiling eyes
    'M33 52 Q40 62 48 52 Q40 57 33 52 Z',             // open grin
    // tragedy mask (right, tilted, overlapping)
    'M55 40 Q68 36 80 38 C79 51 77 62 71 69 C67 74 64 76 63 76 C62 75 59 71 57 64 C54 55 54 47 55 40 Z',
    'M60 49 Q64 46 68 50', 'M70 48 Q74 45 78 49',     // downcast eyes
    'M61 68 Q67 60 73 68 Q67 64 61 68 Z',             // frown
    // motion ticks
    'M22 40 q-2 7 0 13', 'M84 56 q3 5 0 10',
  ] },
};

interface Props { name: string; class?: string; hold?: boolean; }
// hold = draw in as it enters, then STAY drawn (no unravel) — for doodles that
// sit at the bottom of a page where there's no scroll left to finish the pass.
const { name, class: className, hold = false } = Astro.props as Props;
const item = LIB[name] ?? LIB.star;
---
<svg class:list={['sketch', className, hold && 'hold']} viewBox={item.vb} fill="none" aria-hidden="true">
  {item.d.map((d) => <path d={d} pathLength="1" />)}
</svg>

<style>
  .sketch {
    overflow: visible; display: block; width: 100%; height: auto;
    animation: kr-float 7s ease-in-out infinite;
  }
  .sketch path {
    fill: none; stroke: var(--sketch-ink, #ece6d8); stroke-width: 2.6;
    stroke-linecap: round; stroke-linejoin: round;
    filter: url(#kr-pencil); opacity: .9;
  }
  /* draw bound to scroll position as the doodle enters view */
  @supports (animation-timeline: view()) {
    .sketch path {
      stroke-dasharray: 1; stroke-dashoffset: 1;
      animation: kr-draw linear both;
      animation-timeline: view();
      /* full pass through the viewport; the keyframes do the rest */
      animation-range: cover;
    }
    /* draw it in before it reaches centre, hold it whole through the middle,
       then let it unravel again as it scrolls up and out of view */
    @keyframes kr-draw {
      0%   { stroke-dashoffset: 1; }   /* entering from the bottom — not yet drawn */
      39%  { stroke-dashoffset: 0; }   /* fully drawn just before reaching centre */
      61%  { stroke-dashoffset: 0; }   /* stays whole through the middle of the screen */
      100% { stroke-dashoffset: 1; }   /* unravels as it leaves the top */
    }
    /* hold variant: draw in as it enters, then stay drawn (never unravels) */
    .sketch.hold path { animation-name: kr-draw-keep; animation-range: entry 6% cover 42%; }
    @keyframes kr-draw-keep { from { stroke-dashoffset: 1; } to { stroke-dashoffset: 0; } }
  }
  @keyframes kr-float {
    0%, 100% { transform: translateY(0) rotate(-1.5deg); }
    50%      { transform: translateY(-7px) rotate(1.5deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .sketch { animation: none; }
    .sketch path { stroke-dashoffset: 0; animation: none; }
  }
</style>
