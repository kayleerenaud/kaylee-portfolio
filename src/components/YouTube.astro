---
// Responsive, lazy YouTube embed wired to the IFrame API so the page can react
// to play / pause / finish:
//   • while playing → the ambient sound DUCKS, and a dark "spotlight" overlay
//     dims the rest of the page with a HOLE punched exactly over the video, so
//     the video keeps its full original brightness while everything else recedes;
//   • a soft accent light-bleed rings the video for immersion;
//   • if the video scrolls out of view (still playing) the dim fades off so the
//     visitor can keep exploring; it returns when the video scrolls back in;
//   • on pause/finish → everything returns to normal.
const { id, title = 'YouTube video' } = Astro.props as { id: string; title?: string };
const playerId = 'ytp-' + Math.random().toString(36).slice(2, 9);
---
<div class="yt">
  <iframe
    id={playerId}
    src={`https://www.youtube-nocookie.com/embed/${id}?enablejsapi=1&rel=0`}
    title={title}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    referrerpolicy="strict-origin-when-cross-origin"
    allowfullscreen
  ></iframe>
</div>

<style>
  .yt { position: relative; aspect-ratio: 16 / 9; width: 100%; background: #000; border-radius: var(--radius); overflow: hidden; }
  .yt iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
</style>

<script is:inline define:vars={{ playerId }}>
  (() => {
    /* ---- one shared spotlight overlay for the whole page ---- */
    function spotlight() {
      if (window.__krSpot) return window.__krSpot;
      const ov = document.createElement('div'); ov.className = 'kr-spotlight';
      const hole = document.createElement('div'); hole.className = 'kr-spot-hole';
      ov.appendChild(hole); document.body.appendChild(ov);

      const css = document.createElement('style');
      css.textContent = `
        .kr-spotlight { position: fixed; inset: 0; z-index: 70; pointer-events: none; opacity: 0; transition: opacity .45s ease; }
        .kr-spotlight.on { opacity: 1; }
        .kr-spot-hole { position: fixed; border-radius: var(--radius); transition: box-shadow .45s ease;
          box-shadow:
            0 0 60px 12px color-mix(in srgb, var(--accent) 36%, transparent),
            0 0 150px 32px color-mix(in srgb, var(--accent) 14%, transparent),
            0 0 0 9999px rgba(8,6,5,0.62); }
        @media (prefers-reduced-motion: reduce) { .kr-spotlight { transition: none; } }`;
      document.head.appendChild(css);

      let active = null, raf = 0;
      const inView = (r) => r.top < innerHeight * 0.85 && r.bottom > innerHeight * 0.15;
      const place = () => {
        raf = 0;
        if (!active) { ov.classList.remove('on'); return; }
        const r = active.getBoundingClientRect();
        if (inView(r)) {
          hole.style.top = r.top + 'px'; hole.style.left = r.left + 'px';
          hole.style.width = r.width + 'px'; hole.style.height = r.height + 'px';
          ov.classList.add('on');
        } else {
          ov.classList.remove('on');     // scrolled past → un-dim, video keeps playing
        }
      };
      const sched = () => { if (!raf) raf = requestAnimationFrame(place); };
      addEventListener('scroll', sched, { passive: true });
      addEventListener('resize', sched, { passive: true });

      window.__krSpot = {
        play(yt) { active = yt; place(); },
        stop(yt) { if (active === yt) { active = null; ov.classList.remove('on'); } },
      };
      return window.__krSpot;
    }

    function makePlayer() {
      if (!document.getElementById(playerId) || !window.YT || !window.YT.Player) return;
      new window.YT.Player(playerId, {
        events: {
          onStateChange: (e) => {
            const yt = document.getElementById(playerId)?.closest('.yt');
            if (!yt) return;
            const S = window.YT.PlayerState;
            if (e.data === S.PLAYING) {
              yt.classList.add('is-playing');
              spotlight().play(yt);
              window.dispatchEvent(new CustomEvent('kr-duck'));
            } else if (e.data === S.PAUSED || e.data === S.ENDED) {
              yt.classList.remove('is-playing');
              spotlight().stop(yt);
              if (!document.querySelector('.yt.is-playing')) {
                window.dispatchEvent(new CustomEvent('kr-unduck'));
              }
            }
          },
        },
      });
    }

    // shared API loader: one script for any number of embeds
    window.__krYt = window.__krYt || { ready: false, loading: false, queue: [] };
    const reg = (fn) => { window.__krYt.ready ? fn() : window.__krYt.queue.push(fn); };
    reg(makePlayer);
    if (!window.__krYt.loading) {
      window.__krYt.loading = true;
      const prev = window.onYouTubeIframeAPIReady;
      window.onYouTubeIframeAPIReady = () => {
        if (typeof prev === 'function') prev();
        window.__krYt.ready = true;
        window.__krYt.queue.forEach((f) => f());
        window.__krYt.queue = [];
      };
      const tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(tag);
    }
  })();
</script>
