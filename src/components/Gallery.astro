---
// Reusable image/video gallery with caption PREVIEW + click-to-enlarge lightbox.
//
//  • Thumbnail shows a short caption preview in the lower-left corner.
//  • Click/tap enlarges the image; the caption expands to its FULL length.
//  • In the enlarged view you can toggle through every image in that gallery
//    (on-screen arrows, keyboard ← →, or swipe on mobile). Esc / tap-outside closes.
//
// Pass an array of items: { src, alt, caption }.
export type GalleryItem = { src: string; alt: string; caption?: string };
const { items, columns = 3 } = Astro.props as { items: GalleryItem[]; columns?: number };
---
<ul class="gallery" data-gallery style={`--cols:${columns}`}>
  {items.map((it, i) => (
    <li class="cell" data-reveal style={`--d:${(i % 4) * 70}ms`}>
      <button
        class="thumb"
        data-lightbox
        data-index={i}
        data-src={it.src}
        data-alt={it.alt}
        data-caption={it.caption ?? ''}
        aria-label={`Enlarge: ${it.caption || it.alt}`}
      >
        <img src={it.src} alt={it.alt} loading="lazy" decoding="async" />
        {it.caption && <span class="caption">{it.caption}</span>}
      </button>
    </li>
  ))}
</ul>

<style>
  .gallery {
    list-style: none; margin: 0; padding: 0;
    display: grid; gap: var(--gap);
    grid-template-columns: repeat(var(--cols, 3), 1fr);
  }
  @media (max-width: 900px) { .gallery { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .gallery { grid-template-columns: 1fr; } }

  .thumb {
    position: relative; display: block; width: 100%; padding: 0; border: 0;
    background: var(--surface); cursor: zoom-in; overflow: hidden;
    border-radius: var(--radius); line-height: 0;
  }
  .thumb img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; transition: transform .4s ease; }
  .thumb:hover img, .thumb:focus-visible img { transform: scale(1.04); }

  /* caption PREVIEW: lower-left, truncated to 2 lines. Full text lives in the
     lightbox. A subtle accent gradient ties it to the section's mood color. */
  .caption {
    position: absolute; left: 0; right: auto; bottom: 0; max-width: 85%;
    margin: 0.6rem; padding: 0.4rem 0.65rem;
    background: linear-gradient(180deg,
        color-mix(in srgb, var(--accent) 24%, rgba(18,16,13,0.82)),
        rgba(18,16,13,0.86));
    color: #fff; font-size: 0.82rem; line-height: 1.3; border-radius: 3px;
    text-align: left; pointer-events: none;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    opacity: 0; transform: translateY(6px); transition: opacity .2s, transform .2s;
  }
  .thumb:hover .caption, .thumb:focus-visible .caption { opacity: 1; transform: translateY(0); }
  /* On touch devices (no hover), keep previews visible so they aren't hidden. */
  @media (hover: none) { .caption { opacity: 1; transform: none; } }
</style>

<script>
  type Item = { src: string; alt: string; caption: string };

  let LB: HTMLDialogElement | null = null;
  let group: Item[] = [];
  let idx = 0;

  function build(): HTMLDialogElement {
    if (LB) return LB;
    const dlg = document.createElement('dialog');
    dlg.id = 'lightbox';
    dlg.innerHTML = `
      <button class="lb-btn lb-close" aria-label="Close (Esc)">×</button>
      <button class="lb-btn lb-prev" aria-label="Previous image">‹</button>
      <button class="lb-btn lb-next" aria-label="Next image">›</button>
      <figure class="lb-figure">
        <div class="lb-stage"><img class="lb-img" alt="" /></div>
        <figcaption class="lb-cap"></figcaption>
        <div class="lb-count" aria-hidden="true"></div>
      </figure>`;
    document.body.appendChild(dlg);

    const style = document.createElement('style');
    style.textContent = `
      #lightbox { border:0; padding:0; width:100vw; height:100dvh; max-width:100vw; max-height:100dvh; background:transparent; overflow:hidden; }
      #lightbox::backdrop { background: rgba(12,10,9,0.94); backdrop-filter: blur(3px); }
      #lightbox .lb-figure { margin:0; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; padding: 3.5rem 1rem 1.5rem; }
      #lightbox .lb-stage { display:flex; align-items:center; justify-content:center; min-height:0; }
      #lightbox .lb-img { max-width:92vw; max-height:72vh; width:auto; height:auto; border-radius:4px; box-shadow: 0 24px 60px rgba(0,0,0,.5); }
      #lightbox.is-swap .lb-img { opacity:0; transform: translateY(8px); }
      #lightbox .lb-img { transition: opacity .18s ease, transform .18s ease; }
      #lightbox .lb-cap { color:#f3efe9; font-size:1.02rem; line-height:1.55; max-width:68ch; text-align:center; padding:0 1rem; }
      #lightbox .lb-cap:empty { display:none; }
      #lightbox .lb-count { color: color-mix(in srgb, var(--accent) 55%, #cfc9c0); font-size:.8rem; letter-spacing:.14em; text-transform:uppercase; }
      #lightbox .lb-btn { position:fixed; color:#fff; background:rgba(0,0,0,.42); border:0; cursor:pointer; border-radius:50%; line-height:1; transition: background .15s, transform .15s; }
      #lightbox .lb-btn:hover { background: var(--accent); transform: scale(1.06); }
      #lightbox .lb-close { top:1rem; right:1.1rem; width:44px; height:44px; font-size:1.7rem; }
      #lightbox .lb-prev, #lightbox .lb-next { top:50%; transform:translateY(-50%); width:52px; height:52px; font-size:2rem; }
      #lightbox .lb-prev:hover, #lightbox .lb-next:hover { transform: translateY(-50%) scale(1.06); }
      #lightbox .lb-prev { left:1rem; } #lightbox .lb-next { right:1rem; }
      #lightbox.is-single .lb-prev, #lightbox.is-single .lb-next { display:none; }
      @media (max-width:560px){ #lightbox .lb-prev{ left:.4rem } #lightbox .lb-next{ right:.4rem } #lightbox .lb-img{ max-height:64vh } }
    `;
    document.head.appendChild(style);

    dlg.querySelector('.lb-close')!.addEventListener('click', () => dlg.close());
    dlg.querySelector('.lb-prev')!.addEventListener('click', () => step(-1));
    dlg.querySelector('.lb-next')!.addEventListener('click', () => step(1));
    // tap the backdrop (the dialog itself, outside the figure) to close
    dlg.addEventListener('click', (e) => {
      const fig = dlg.querySelector('.lb-figure')!;
      if (!fig.contains(e.target as Node) && !(e.target as HTMLElement).closest('.lb-btn')) dlg.close();
    });
    // keyboard
    dlg.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); step(-1); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); step(1); }
    });
    // swipe
    let x0 = 0, y0 = 0;
    dlg.addEventListener('touchstart', (e) => { x0 = e.touches[0].clientX; y0 = e.touches[0].clientY; }, { passive: true });
    dlg.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - x0;
      const dy = e.changedTouches[0].clientY - y0;
      if (Math.abs(dx) > 45 && Math.abs(dx) > Math.abs(dy)) step(dx < 0 ? 1 : -1);
    }, { passive: true });

    LB = dlg;
    return dlg;
  }

  function render() {
    if (!LB) return;
    const it = group[idx];
    const img = LB.querySelector('.lb-img') as HTMLImageElement;
    const cap = LB.querySelector('.lb-cap') as HTMLElement;
    const count = LB.querySelector('.lb-count') as HTMLElement;
    LB.classList.add('is-swap');
    const swap = () => {
      img.src = it.src; img.alt = it.alt;
      cap.textContent = it.caption;
      count.textContent = group.length > 1 ? `${idx + 1} / ${group.length}` : '';
      requestAnimationFrame(() => LB!.classList.remove('is-swap'));
    };
    // brief fade so toggling reads as a deliberate step, never a long dissolve
    if (img.src) setTimeout(swap, 120); else swap();
  }

  function step(dir: number) {
    if (group.length < 2) return;
    idx = (idx + dir + group.length) % group.length;
    render();
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-lightbox]') as HTMLElement | null;
    if (!btn) return;
    const root = btn.closest('[data-gallery]');
    if (!root) return;
    const thumbs = Array.from(root.querySelectorAll<HTMLElement>('[data-lightbox]'));
    group = thumbs.map((t) => ({ src: t.dataset.src || '', alt: t.dataset.alt || '', caption: t.dataset.caption || '' }));
    idx = Number(btn.dataset.index || 0);
    const dlg = build();
    dlg.classList.toggle('is-single', group.length < 2);
    render();
    dlg.showModal();
  });
</script>
