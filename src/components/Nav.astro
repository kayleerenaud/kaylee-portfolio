---
import { site, pages, pageHref } from '../config/site';
const { current } = Astro.props as { current: string };
const navPages = pages.filter((p) => p.inNav !== false);
---
<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/">{site.brand}</a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav" aria-label="Primary">
      {navPages.map((p) => (
        <a
          href={pageHref(p.slug)}
          class:list={['nav-link', { active: p.slug === current }]}
          aria-current={p.slug === current ? 'page' : undefined}
        >{p.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(1.2) blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .bar { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .brand {
    font-family: var(--font-display);
    font-size: 1.25rem; font-weight: 600; color: var(--ink);
    text-decoration: none; letter-spacing: 0.01em;
  }
  .nav { display: flex; gap: clamp(0.75rem, 2vw, 1.75rem); }
  .nav-link {
    color: var(--ink-soft); text-decoration: none; font-size: 0.95rem;
    padding: 0.25rem 0; border-bottom: 2px solid transparent; transition: color .15s, border-color .15s;
  }
  .nav-link:hover { color: var(--ink); text-decoration: none; }
  .nav-link.active { color: var(--ink); border-bottom-color: var(--accent); }

  /* mobile menu */
  .nav-toggle, .nav-burger { display: none; }
  @media (max-width: 720px) {
    .nav-burger {
      display: flex; flex-direction: column; gap: 5px; cursor: pointer; padding: 8px;
    }
    .nav-burger span { width: 24px; height: 2px; background: var(--ink); border-radius: 2px; }
    .nav {
      position: absolute; top: 64px; left: 0; right: 0;
      flex-direction: column; gap: 0; background: var(--surface);
      border-bottom: 1px solid var(--line);
      max-height: 0; overflow: hidden; transition: max-height .25s ease;
    }
    .nav-link { padding: 0.85rem var(--gap); border-bottom: 1px solid var(--line); }
    .nav-toggle:checked ~ .nav { max-height: 60vh; }
  }
</style>
