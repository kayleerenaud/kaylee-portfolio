---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Atmosphere from '../components/Atmosphere.astro';
import { site, getPage } from '../config/site';

const { title, description, current = '' } = Astro.props as {
  title?: string;
  description?: string;
  current?: string;
};
const page = getPage(current);
const fullTitle = title ? `${title} · ${site.brand}` : `${site.brand} — ${site.tagline}`;
const desc = description ?? site.tagline;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content={page.accent} />
    <link rel="preload" href="/fonts/KayleeScript-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600&display=swap" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
  </head>
  <!-- this page's signature accent; the Atmosphere layer shifts it as you scroll -->
  <body style={`--accent:${page.accent}`}>
    <Nav current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer current={current} />
    <Atmosphere tone={page.tone} />
  </body>
</html>
