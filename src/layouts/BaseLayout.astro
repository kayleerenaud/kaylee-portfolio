---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Atmosphere from '../components/Atmosphere.astro';
import { site, getPage } from '../config/site';
import Analytics from '@vercel/analytics/astro';

const { title, description, current = '' } = Astro.props as {
  title?: string;
  description?: string;
  current?: string;
};
const page = getPage(current);
const fullTitle = title ? `${title} · ${site.brand}` : `${site.brand} — ${site.tagline}`;
const desc = description ?? site.tagline;
// absolute URLs for canonical + social share cards (Astro.site = kayleerenaud.com)
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og-image.jpg', Astro.site).href;
// structured data: tell Google this is a real person + link to her socials
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.brand,
  url: Astro.site?.href ?? canonical,
  image: ogImage,
  jobTitle: 'Filmmaker, Costume Designer & Writer',
  sameAs: Object.values(site.social).filter(Boolean),
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content={page.accent} />
    <link rel="preload" href="/fonts/KayleeScript-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600&display=swap" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.brand} — ${site.tagline}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  </head>
  <!-- this page's signature accent; the Atmosphere layer shifts it as you scroll -->
  <body style={`--accent:${page.accent}`}>
    <Nav current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer current={current} />
    <Atmosphere tone={page.tone} />
    <Analytics />
  </body>
</html>
