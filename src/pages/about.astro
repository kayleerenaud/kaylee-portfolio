---
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import { aboutPhotos } from '../data/galleries';
---
<BaseLayout current="about" title="About" description="About Kaylee Renaud.">
  <section class="container page-intro">
    <h1 data-reveal>About</h1>
    <p class="placeholder-note" data-reveal style="--d:60ms">Your blurb goes here — send it whenever and I'll drop it in. Below is placeholder text + spots for a few photos of you.</p>
    <p data-reveal style="--d:120ms">
      Hi, I'm Kaylee. <em>[Your blurb will live here.]</em> Lorem ipsum dolor sit amet,
      consectetur adipiscing elit. I work across film, costume, and writing —
      tell your story in a couple of warm, personal paragraphs and we'll style it to feel like you.
    </p>
  </section>

  <section class="container">
    <Gallery items={aboutPhotos} columns={3} />
  </section>
</BaseLayout>
