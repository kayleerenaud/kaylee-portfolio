---
import BaseLayout from '../layouts/BaseLayout.astro';
import Headshot from '../components/Headshot.astro';
import Sketch from '../components/Sketch.astro';
import { blurb, basedIn, headshotFrames, crafts, credits } from '../data/about';
import { site, pageHref } from '../config/site';
---
<BaseLayout current="about" title="About" description="About Kaylee Renaud — film, costume, and writing.">
  <!-- soft, grainy "pencil" filter used by every doodle (rendered once) -->
  <svg width="0" height="0" class="kr-defs" aria-hidden="true" focusable="false">
    <defs>
      <filter id="kr-pencil" x="-30%" y="-30%" width="160%" height="160%">
        <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="2" seed="7" result="warp" />
        <feDisplacementMap in="SourceGraphic" in2="warp" scale="2.4" xChannelSelector="R" yChannelSelector="G" result="wobbled" />
        <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3" seed="4" result="grain" />
        <feComponentTransfer in="grain" result="grainA">
          <feFuncA type="discrete" tableValues="1 1 1 0 1 1 1 0 1 1" />
        </feComponentTransfer>
        <feComposite in="wobbled" in2="grainA" operator="in" />
      </filter>
    </defs>
  </svg>

  <!-- 1 · TITLE CARD ------------------------------------------------------- -->
  <section class="title-card">
    <div class="container tc-grid">
      <div class="tc-copy">
        <h1 class="tc-name" data-reveal>{site.brand}</h1>
        <p class="tc-credit" data-reveal style="--d:120ms">Filmmaker · Costume Designer · Writer</p>
        <p class="tc-loc" data-reveal style="--d:240ms">{basedIn}</p>
      </div>
      <div class="tc-photo" data-reveal style="--d:160ms">
        <Headshot frames={headshotFrames} alt="Portrait of Kaylee Renaud" />
      </div>
    </div>
  </section>

  <!-- 2 · BLURB ------------------------------------------------------------ -->
  <section class="blurb-section">
    <div class="container blurb-inner">
      {blurb.map((p, i) => <p class="blurb-p" data-reveal style={`--d:${i * 80}ms`} set:html={p} />)}
    </div>
  </section>

  <!-- 3 · FEATURING (the three crafts) ------------------------------------- -->
  <section class="container featuring">
    <ul class="craft-grid">
      {crafts.map((c, i) => (
        <li class="craft" data-reveal style={`--d:${i * 90}ms`}>
          <a class="craft-link" href={c.href}>
            <span class="craft-sketch"><Sketch name={c.sketch} /></span>
            <span class="craft-label">{c.label}</span>
            <span class="craft-blurb">{c.blurb}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- 4 · CREDITS (no label — the styling carries the vibe) ----------------- -->
  <section class="credits-section">
    <div class="container">
      <div class="credits-roll">
        {credits.map((group, gi) => (
          <div class="credit-group" data-reveal style={`--d:${gi * 70}ms`}>
            <span class="credit-sketch"><Sketch name={group.sketch} /></span>
            <p class="credit-heading">{group.heading}</p>
            {group.lines.map((line) => <p class="credit-line">{line}</p>)}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5 · CONTACT INVITE --------------------------------------------------- -->
  <section class="invite-section">
    <div class="container invite">
      <h2 class="invite-title" data-reveal>Let's make something.</h2>
      <div class="invite-actions" data-reveal style="--d:120ms">
        <a class="btn-solid" href={pageHref('contact')}>Get in touch →</a>
        <a class="btn-ghost" href={`mailto:${site.email}`}>{site.email}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .kr-defs { position: absolute; }

  /* ---- 1 · title card: letterboxed like an opening frame ---- */
  .title-card { position: relative; padding: clamp(2.5rem, 7vw, 5rem) 0; }
  .tc-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(1.5rem, 5vw, 4rem); align-items: center; min-height: 56vh; }
  @media (max-width: 760px) { .tc-grid { grid-template-columns: 1fr; text-align: center; } .tc-photo { justify-self: center; } }
  .tc-name { font-size: clamp(2.8rem, 9vw, 6rem); line-height: .95; margin: 0; }
  .tc-hook { font-size: clamp(1.15rem, 2.6vw, 1.6rem); color: var(--ink); margin: 1.2rem 0 1rem; max-width: 30ch; }
  @media (max-width: 760px) { .tc-hook { margin-inline: auto; } }
  .tc-credit { font-family: var(--font-mono); font-size: .82rem; letter-spacing: .1em; color: var(--ink-soft); margin: 1.3rem 0 0; }
  .tc-loc { font-family: var(--font-mono); font-size: .82rem; letter-spacing: .1em; color: var(--accent); margin: .35rem 0 0; }
  .tc-photo { display: flex; justify-content: flex-end; }

  /* ---- 2 · blurb ---- */
  .blurb-section { position: relative; }
  .blurb-inner { padding-block: clamp(3rem, 8vw, 6rem) clamp(2rem, 5vw, 3.5rem); max-width: 64ch; }
  .blurb-p { font-size: 1.2rem; line-height: 1.75; color: var(--ink); margin: 0 0 1.5rem; }
  .blurb-p em {
    font-family: var(--font-hand); font-style: normal; font-weight: 600;
    font-size: 1.4em; line-height: 1; color: var(--accent);
  }

  /* ---- 3 · featuring ---- */
  .featuring { position: relative; padding-block: clamp(2rem, 5vw, 3rem); }
  .section-kicker { font-family: var(--font-mono); font-size: .8rem; letter-spacing: .22em; text-transform: uppercase; color: var(--accent); text-align: center; margin: 0 0 2rem; }
  .craft-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap); }
  @media (max-width: 700px) { .craft-grid { grid-template-columns: 1fr; } }
  .craft-link { display: flex; flex-direction: column; align-items: center; text-align: center; gap: .5rem; padding: 1.5rem 1rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); color: var(--ink); transition: transform .15s, border-color .15s; }
  .craft-link:hover { text-decoration: none; transform: translateY(-3px); border-color: var(--accent); }
  .craft-sketch { width: 64px; height: 64px; display: grid; place-items: center; }
  .craft-label { font-family: var(--font-display); font-size: 1.5rem; }
  .craft-blurb { color: var(--ink-soft); font-size: .95rem; max-width: 26ch; }

  /* ---- 4 · credits ---- */
  .credits-section { position: relative; padding: clamp(3rem, 8vw, 6rem) 0; background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--accent) 5%, transparent), transparent); }
  .credits-roll { display: flex; flex-direction: column; gap: 2.75rem; align-items: center; text-align: center; }
  .credit-sketch { display: block; width: 54px; height: 54px; margin: 0 auto .6rem; }
  .credit-heading { font-family: var(--font-display); font-size: 1.25rem; color: var(--accent); margin: 0 0 .6rem; letter-spacing: .02em; }
  .credit-line { font-family: var(--font-mono); font-size: .95rem; line-height: 1.7; color: var(--ink-soft); margin: 0; }

  /* ---- 5 · invite ---- */
  .invite-section { position: relative; }
  .invite { text-align: center; padding-block: clamp(3rem, 8vw, 6rem) clamp(2rem, 5vw, 3rem); }
  .invite-title { font-size: clamp(2rem, 6vw, 3.5rem); margin: 0 0 2rem; }
  .invite-sub { color: var(--ink-soft); font-size: 1.15rem; margin: 0 0 1.8rem; }
  .invite-actions { display: flex; gap: 1.5rem; align-items: center; justify-content: center; flex-wrap: wrap; }
  .btn-solid { background: var(--accent); color: var(--on-accent); font-weight: 600; padding: .7rem 1.5rem; border-radius: var(--radius); transition: filter .15s; }
  .btn-solid:hover { text-decoration: none; filter: brightness(1.08); }
  .btn-ghost { color: var(--ink-soft); border-bottom: 1px solid var(--line); padding-bottom: 2px; }
  .btn-ghost:hover { color: var(--ink); text-decoration: none; }

  /* ---- margin doodles: small, in the gutters, never over the content ----
     (only shown when there's real gutter room; all sit below the fold so the
     scroll-draw always triggers as they enter the viewport) */
</style>
