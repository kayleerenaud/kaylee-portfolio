---
import BaseLayout from '../layouts/BaseLayout.astro';
import Headshot from '../components/Headshot.astro';
import Sketch from '../components/Sketch.astro';
import { hook, blurb, basedIn, headshotFrames, crafts, credits } from '../data/about';
import { site, pageHref } from '../config/site';
---
<BaseLayout current="about" title="About" description="About Kaylee Renaud — film, costume, and writing.">
  <!-- pencil filter used by every doodle (rendered once) -->
  <svg width="0" height="0" class="kr-defs" aria-hidden="true" focusable="false">
    <defs>
      <filter id="kr-pencil" x="-25%" y="-25%" width="150%" height="150%">
        <feTurbulence type="fractalNoise" baseFrequency="0.018 0.04" numOctaves="2" seed="7" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="2.6" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <!-- 1 · TITLE CARD ------------------------------------------------------- -->
  <section class="title-card">
    <div class="container tc-grid">
      <div class="tc-copy">
        <p class="tc-kicker" data-reveal>A short film about —</p>
        <h1 class="tc-name" data-reveal style="--d:60ms">{site.brand}</h1>
        <p class="tc-hook" data-reveal style="--d:140ms">{hook}</p>
        <p class="tc-credit" data-reveal style="--d:220ms">Written · Shot · Stitched by {site.brand}</p>
      </div>
      <div class="tc-photo" data-reveal style="--d:160ms">
        <Headshot frames={headshotFrames} alt="Portrait of Kaylee Renaud" />
      </div>
    </div>
    <Sketch name="star" class="doodle d-tc-star" />
  </section>

  <!-- 2 · BLURB ------------------------------------------------------------ -->
  <section class="container blurb">
    {blurb.map((p, i) => <p class="blurb-p" data-reveal style={`--d:${i * 80}ms`}>{p}</p>)}
    <Sketch name="squiggle" class="doodle d-blurb" />
    <Sketch name="heart" class="doodle d-blurb2" />
  </section>

  <!-- 3 · FEATURING (the three crafts) ------------------------------------- -->
  <section class="container featuring">
    <p class="section-kicker" data-reveal>Featuring</p>
    <ul class="craft-grid">
      {crafts.map((c, i) => (
        <li class="craft" data-reveal style={`--d:${i * 90}ms`}>
          <a class="craft-link" href={c.href}>
            <span class="craft-sketch"><Sketch name={c.sketch} /></span>
            <span class="craft-label">{c.label}</span>
            <span class="craft-blurb">{c.blurb}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- 4 · BASED IN --------------------------------------------------------- -->
  <section class="container based">
    <span class="based-pin"><Sketch name="pin" /></span>
    <p class="based-text" data-reveal>{basedIn}</p>
  </section>

  <!-- 5 · END CREDITS ------------------------------------------------------ -->
  <section class="credits-section">
    <div class="container">
      <p class="credits-head" data-reveal>End Credits</p>
      <div class="credits-roll">
        {credits.map((group, gi) => (
          <div class="credit-group" data-reveal style={`--d:${gi * 70}ms`}>
            <p class="credit-heading">{group.heading}</p>
            {group.lines.map((line) => <p class="credit-line">{line}</p>)}
          </div>
        ))}
      </div>
    </div>
    <Sketch name="spark" class="doodle d-credits" />
  </section>

  <!-- 6 · CONTACT INVITE --------------------------------------------------- -->
  <section class="container invite">
    <h2 class="invite-title" data-reveal>Let's make something.</h2>
    <p class="invite-sub" data-reveal style="--d:80ms">A project, a question, or just a hello — I read everything.</p>
    <div class="invite-actions" data-reveal style="--d:160ms">
      <a class="btn-solid" href={pageHref('contact')}>Get in touch →</a>
      <a class="btn-ghost" href={`mailto:${site.email}`}>{site.email}</a>
    </div>
    <Sketch name="arrow" class="doodle d-invite" />
  </section>
</BaseLayout>

<style>
  .kr-defs { position: absolute; }

  /* ---- 1 · title card: letterboxed like an opening frame ---- */
  .title-card { position: relative; padding: clamp(2.5rem, 7vw, 5rem) 0; border-bottom: 1px solid var(--line); overflow: hidden; }
  .title-card::before, .title-card::after { content: ''; position: absolute; left: 0; right: 0; height: 26px; background: #000; opacity: .5; }
  .title-card::before { top: 0; } .title-card::after { bottom: 0; }
  .tc-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(1.5rem, 5vw, 4rem); align-items: center; min-height: 60vh; }
  @media (max-width: 760px) { .tc-grid { grid-template-columns: 1fr; text-align: center; } .tc-photo { justify-self: center; } }
  .tc-kicker { font-family: var(--font-mono); font-size: .85rem; letter-spacing: .2em; text-transform: uppercase; color: var(--accent); margin: 0 0 .5rem; }
  .tc-name { font-size: clamp(2.8rem, 9vw, 6rem); line-height: .95; margin: 0; }
  .tc-hook { font-size: clamp(1.15rem, 2.6vw, 1.6rem); color: var(--ink); margin: 1.2rem 0 .8rem; max-width: 30ch; }
  @media (max-width: 760px) { .tc-hook { margin-inline: auto; } }
  .tc-credit { font-family: var(--font-mono); font-size: .8rem; letter-spacing: .1em; color: var(--ink-soft); margin: 0; }
  .tc-photo { display: flex; justify-content: flex-end; }

  /* ---- 2 · blurb ---- */
  .blurb { position: relative; padding: clamp(3rem, 8vw, 6rem) 0 clamp(2rem, 5vw, 3.5rem); max-width: 64ch; }
  .blurb-p { font-size: 1.2rem; line-height: 1.7; color: var(--ink); margin: 0 0 1.4rem; }

  /* ---- 3 · featuring ---- */
  .featuring { padding: clamp(2rem, 5vw, 3rem) 0; }
  .section-kicker { font-family: var(--font-mono); font-size: .8rem; letter-spacing: .22em; text-transform: uppercase; color: var(--accent); text-align: center; margin: 0 0 2rem; }
  .craft-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap); }
  @media (max-width: 700px) { .craft-grid { grid-template-columns: 1fr; } }
  .craft-link { display: flex; flex-direction: column; align-items: center; text-align: center; gap: .5rem; padding: 1.5rem 1rem; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); color: var(--ink); transition: transform .15s, border-color .15s; }
  .craft-link:hover { text-decoration: none; transform: translateY(-3px); border-color: var(--accent); }
  .craft-sketch { width: 64px; height: 64px; display: grid; place-items: center; }
  .craft-label { font-family: var(--font-display); font-size: 1.5rem; }
  .craft-blurb { color: var(--ink-soft); font-size: .95rem; max-width: 24ch; }

  /* ---- 4 · based in ---- */
  .based { position: relative; display: flex; align-items: center; justify-content: center; gap: .75rem; padding: clamp(2rem, 5vw, 3.5rem) 0; }
  .based-pin { width: 34px; height: 40px; display: block; flex: 0 0 auto; }
  .based-text { font-family: var(--font-mono); font-size: 1rem; letter-spacing: .08em; color: var(--ink-soft); margin: 0; }

  /* ---- 5 · end credits ---- */
  .credits-section { position: relative; padding: clamp(3rem, 8vw, 6rem) 0; border-top: 1px solid var(--line); background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--accent) 6%, transparent)); overflow: hidden; }
  .credits-head { font-family: var(--font-mono); font-size: .8rem; letter-spacing: .25em; text-transform: uppercase; color: var(--accent); text-align: center; margin: 0 0 2.5rem; }
  .credits-roll { display: flex; flex-direction: column; gap: 2.5rem; align-items: center; text-align: center; }
  .credit-heading { font-family: var(--font-display); font-size: 1.25rem; color: var(--accent); margin: 0 0 .6rem; letter-spacing: .02em; }
  .credit-line { font-family: var(--font-mono); font-size: .95rem; line-height: 1.7; color: var(--ink-soft); margin: 0; }

  /* ---- 6 · invite ---- */
  .invite { position: relative; text-align: center; padding: clamp(3rem, 8vw, 6rem) 0 clamp(2rem, 5vw, 3rem); }
  .invite-title { font-size: clamp(2rem, 6vw, 3.5rem); margin: 0 0 .5rem; }
  .invite-sub { color: var(--ink-soft); font-size: 1.15rem; margin: 0 0 1.8rem; }
  .invite-actions { display: flex; gap: 1.5rem; align-items: center; justify-content: center; flex-wrap: wrap; }
  .btn-solid { background: var(--accent); color: #14110f; font-weight: 600; padding: .7rem 1.5rem; border-radius: var(--radius); transition: filter .15s; }
  .btn-solid:hover { text-decoration: none; filter: brightness(1.08); }
  .btn-ghost { color: var(--ink-soft); border-bottom: 1px solid var(--line); padding-bottom: 2px; }
  .btn-ghost:hover { color: var(--ink); text-decoration: none; }

  /* ---- margin doodles (placed in the gutters; hidden when too narrow) ---- */
  .doodle { position: absolute; z-index: 1; pointer-events: none; color: var(--accent); }
  .d-tc-star  { width: 58px; top: 14%;  right: 6%; }
  .d-blurb    { width: 90px; top: 8%;   right: -2%; }
  .d-blurb2   { width: 54px; bottom: 6%; left: -3%; }
  .d-credits  { width: 60px; top: 12%;  left: 5%; }
  .d-invite   { width: 84px; bottom: 8%; right: 8%; }
  @media (max-width: 1100px) { .d-blurb, .d-blurb2, .d-credits { display: none; } }
  @media (max-width: 760px)  { .doodle { display: none; } }
</style>
