---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cvProfile, education, hardSkills, softSkills, timeline, references } from '../data/cv';
---
<BaseLayout current="" title="CV" description="Curriculum vitae — Kaylee Renaud, writer, filmmaker, and costume designer.">
  <section class="container cv">
    <!-- header -->
    <header class="cv-head">
      <div class="cv-id">
        <h1>{cvProfile.name}</h1>
        <p class="cv-title">{cvProfile.title}</p>
      </div>
      <button class="cv-print-btn" type="button" onclick="window.print()">↓ Save as PDF</button>
    </header>

    <div class="cv-grid">
      <!-- sidebar -->
      <aside class="cv-side">
        <img class="cv-photo" src="/kaylee-headshot.jpg" alt="Portrait of Kaylee Renaud" width="900" height="900" />

        <div class="cv-block">
          <h2 class="cv-h">Contact</h2>
          <ul class="cv-contact">
            <li><a href={`mailto:${cvProfile.email}`}>{cvProfile.email}</a></li>
            <li>{cvProfile.phone}</li>
            <li>{cvProfile.location}</li>
          </ul>
        </div>

        <div class="cv-block">
          <h2 class="cv-h">Skills</h2>
          <div class="cv-tags">{hardSkills.map((s) => <span>{s}</span>)}</div>
        </div>

        <div class="cv-block">
          <h2 class="cv-h">Strengths</h2>
          <div class="cv-tags soft">{softSkills.map((s) => <span>{s}</span>)}</div>
        </div>

        <div class="cv-block">
          <h2 class="cv-h">Education</h2>
          {education.map((e) => (
            <div class="cv-edu">
              <p class="cv-edu-deg">{e.degree}</p>
              <p class="cv-edu-school">{e.school}</p>
              <p class="cv-edu-detail">{e.detail}</p>
              <p class="cv-edu-date">{e.date}</p>
            </div>
          ))}
        </div>

        <div class="cv-block">
          <h2 class="cv-h">References</h2>
          {references.map((r) => (
            <div class="cv-ref">
              <p class="cv-ref-name">{r.name}</p>
              <p class="cv-ref-role">{r.role}</p>
              <p class="cv-ref-contact">{r.contact}</p>
            </div>
          ))}
        </div>
      </aside>

      <!-- main column -->
      <main class="cv-main">
        <p class="cv-bio">{cvProfile.bio}</p>

        <h2 class="cv-section">Experience</h2>
        <div class="cv-track">
          {timeline.map((group) => (
            <>
              <h3 class="cv-year">{group.year}</h3>
              {group.entries.map((en) => (
                <article class="cv-entry">
                  <h4 class="cv-entry-title">{en.title}</h4>
                  {en.role && <p class="cv-role">{en.role}</p>}
                  <ul>{en.lines.map((l) => <li>{l}</li>)}</ul>
                </article>
              ))}
            </>
          ))}
        </div>
      </main>
    </div>
  </section>
</BaseLayout>

<style>
  .cv { padding-block: clamp(2rem, 5vw, 4rem) clamp(3rem, 7vw, 5rem); }

  /* header */
  .cv-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    border-bottom: 2px solid color-mix(in srgb, var(--accent) 40%, var(--line)); padding-bottom: 1rem; margin-bottom: clamp(1.75rem, 4vw, 2.75rem); }
  .cv-id h1 { margin: 0; line-height: 1; }
  .cv-title { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .2em; font-size: .8rem; color: var(--accent); margin: .5rem 0 0; }
  .cv-print-btn { font-family: var(--font-mono); font-size: .78rem; letter-spacing: .06em; color: var(--ink);
    background: color-mix(in srgb, var(--accent) 14%, var(--surface)); border: 1px solid color-mix(in srgb, var(--accent) 55%, var(--line));
    border-radius: var(--radius); padding: .5rem 1rem; cursor: pointer; transition: background .15s, transform .15s; }
  .cv-print-btn:hover { background: color-mix(in srgb, var(--accent) 24%, var(--surface)); transform: translateY(-1px); }

  /* layout */
  .cv-grid { display: grid; grid-template-columns: 300px 1fr; gap: clamp(2rem, 4vw, 3.5rem); align-items: start; }
  @media (max-width: 760px) { .cv-grid { grid-template-columns: 1fr; gap: 2.25rem; } }

  /* sidebar */
  .cv-photo { width: 200px; height: 200px; border-radius: 50%; object-fit: cover; display: block; margin: 0 0 1.5rem;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 70%, transparent), 0 10px 30px rgba(0,0,0,.4); }
  .cv-block { margin-bottom: 1.6rem; }
  .cv-h { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .2em; font-size: .72rem; color: var(--accent);
    margin: 0 0 .7rem; padding-bottom: .35rem; border-bottom: 1px solid var(--line); }
  .cv-contact { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .3rem; font-size: .92rem; color: var(--ink-soft); }
  .cv-tags { display: flex; flex-wrap: wrap; gap: .4rem; }
  .cv-tags span { font-size: .76rem; color: var(--ink); border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--line));
    background: color-mix(in srgb, var(--accent) 8%, transparent); border-radius: 999px; padding: .22rem .65rem; }
  .cv-tags.soft span { color: var(--ink-soft); background: transparent; }
  .cv-edu-deg { font-weight: 600; color: var(--ink); margin: 0; }
  .cv-edu-school { color: var(--ink-soft); margin: .15rem 0 0; font-size: .92rem; }
  .cv-edu-detail { color: var(--ink-soft); margin: .15rem 0 0; font-size: .85rem; font-style: italic; }
  .cv-edu-date { color: var(--accent); margin: .25rem 0 0; font-family: var(--font-mono); font-size: .76rem; letter-spacing: .04em; }
  .cv-ref { margin-bottom: .9rem; }
  .cv-ref-name { font-weight: 600; color: var(--ink); margin: 0; }
  .cv-ref-role { color: var(--ink-soft); margin: .1rem 0 0; font-size: .84rem; }
  .cv-ref-contact { color: var(--accent); margin: .1rem 0 0; font-size: .82rem; }

  /* main */
  .cv-bio { font-size: 1.08rem; line-height: 1.7; color: var(--ink); margin: 0 0 2.25rem; max-width: 62ch; }
  .cv-section { font-family: var(--font-hand); font-weight: 700; font-size: clamp(1.9rem, 4.5vw, 2.6rem);
    color: var(--ink); margin: 0 0 1.5rem; -webkit-text-stroke: .7px currentColor; }

  /* experience timeline — the site's thread motif, vertical */
  .cv-track { position: relative; padding-left: 1.9rem; border-left: 2px solid color-mix(in srgb, var(--accent) 40%, var(--line)); }
  .cv-year { position: relative; font-family: var(--font-hand); font-weight: 700; -webkit-text-stroke: .5px currentColor;
    font-size: clamp(1.6rem, 3.5vw, 2.1rem); color: var(--accent); margin: 2.2rem 0 1.1rem; }
  .cv-year:first-child { margin-top: 0; }
  .cv-year::before { content: ''; position: absolute; left: calc(-1.9rem - 7px); top: .42em; width: 13px; height: 13px;
    border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 18%, transparent); }
  .cv-entry { position: relative; margin: 0 0 1.4rem; }
  .cv-entry::before { content: ''; position: absolute; left: calc(-1.9rem - 4px); top: .5em; width: 7px; height: 7px;
    border-radius: 50%; background: color-mix(in srgb, var(--accent) 65%, var(--ink-soft)); }
  .cv-entry-title { font-weight: 700; font-size: 1.06rem; color: var(--ink); margin: 0; }
  .cv-role { font-family: var(--font-mono); font-size: .76rem; letter-spacing: .03em; color: var(--accent); margin: .2rem 0 .35rem; }
  .cv-entry ul { margin: 0; padding-left: 1.1rem; }
  .cv-entry li { color: var(--ink-soft); line-height: 1.55; margin-bottom: .2rem; }

  /* ── print / Save-as-PDF: isolate the CV, keep the dark aesthetic ── */
  @media print {
    :global(body *) { visibility: hidden !important; }
    :global(.cv), :global(.cv *) { visibility: visible !important; }
    :global(.cv) { position: absolute; left: 0; top: 0; width: 100%; padding: 0 !important; }
    :global(html), :global(body) { background: #14110f !important; }
    :global(html) { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    .cv-print-btn { display: none !important; }
    .cv-grid { gap: 1.5rem; }
    .cv-entry { break-inside: avoid; }
    .cv-year { break-after: avoid; }
  }
</style>
