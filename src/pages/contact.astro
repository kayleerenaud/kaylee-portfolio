---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../config/site';
---
<BaseLayout current="contact" title="Contact" description="Get in touch with Kaylee Renaud.">
  <section class="container page-intro">
    <h1 data-reveal>Contact</h1>
    <p data-reveal style="--d:80ms">Have a project, a question, or just want to say hello? Send a note! I read everything and I'll get back to you.</p>
    <p class="socials" data-reveal style="--d:140ms">
      {site.social.instagram && <a href={site.social.instagram} target="_blank" rel="noopener">Instagram ↗</a>}
      {site.social.youtube && <a href={site.social.youtube} target="_blank" rel="noopener">YouTube ↗</a>}
    </p>
  </section>

  <section class="container">
    <ContactForm />
  </section>

  <!-- Downloads: drop the real files at public/kaylee-renaud-resume.pdf and
       public/kaylee-renaud-cv.pdf and these buttons serve them automatically. -->
  <section class="container downloads" data-reveal>
    <h2 class="dl-head">Take it with you</h2>
    <div class="dl-row">
      <a class="dl-btn" href="/kaylee-renaud-resume.pdf" download>
        <span class="dl-ic" aria-hidden="true">↓</span> Download résumé
      </a>
      <a class="dl-btn" href="/kaylee-renaud-cv.pdf" download>
        <span class="dl-ic" aria-hidden="true">↓</span> Download CV
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .socials { display: flex; gap: 1.5rem; }
  .downloads { margin-top: clamp(2.5rem, 6vw, 4rem); }
  .dl-head { font-size: 1.15rem; letter-spacing: .03em; color: var(--ink-soft); margin: 0 0 1rem; }
  .dl-row { display: flex; gap: 1rem; flex-wrap: wrap; }
  .dl-btn {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.75rem 1.4rem; border-radius: var(--radius);
    border: 1px solid color-mix(in srgb, var(--accent) 55%, var(--line));
    background: color-mix(in srgb, var(--accent) 12%, var(--surface));
    color: var(--ink); font-size: 1rem; transition: background .15s, border-color .15s, transform .15s;
  }
  .dl-btn:hover { text-decoration: none; transform: translateY(-2px); border-color: var(--accent); background: color-mix(in srgb, var(--accent) 20%, var(--surface)); }
  .dl-ic { color: var(--accent); font-weight: 700; }
</style>
