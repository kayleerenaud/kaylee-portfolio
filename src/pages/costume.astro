---
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import { costume } from '../data/galleries';
---
<BaseLayout current="costume" title="Costume" description="Costume work by Kaylee Renaud.">
  <section class="container page-intro">
    <h1 data-reveal>Costume</h1>
    <p data-reveal style="--d:80ms">Hand-made pieces and the details inside them. A short caption previews in the corner — tap to enlarge and read the full process note.</p>
  </section>
  <section class="container">
    <Gallery items={costume} columns={3} />
  </section>
</BaseLayout>
