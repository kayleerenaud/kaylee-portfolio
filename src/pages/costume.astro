---
import BaseLayout from '../layouts/BaseLayout.astro';
import Lightbox from '../components/Lightbox.astro';
import { projects, upcoming } from '../data/costume';
import { site } from '../config/site';

const dirName = (d: string) => d.replace(/^Dir\.\s*/, '');
// the card's cover image: a finished look if there is one, else the lead rendering
const cover = (p: { pieces: { final?: string; rendering?: string }[] }) =>
  p.pieces.find((x) => x.final)?.final ?? p.pieces.find((x) => x.rendering)?.rendering ?? '';
// per-card randomness: tilt + where the tape catches the light / crinkles
const liStyle = (i: number) => {
  const r = (k: number) => { const x = Math.sin(i * 53.3 + k * 17.1) * 1e4; return x - Math.floor(x); };
  return `--i:${i}; --d:${(i % 3) * 70}ms; ` +
    `--jit:${(r(5) * 9 - 4.5).toFixed(1)}deg; ` +
    `--shineA:${(95 + r(1) * 55).toFixed(0)}deg; ` +
    `--s1:${(20 + r(2) * 28).toFixed(0)}%; ` +
    `--s2:${(54 + r(3) * 30).toFixed(0)}%; ` +
    `--crA:${(100 + r(4) * 40).toFixed(0)}deg;`;
};

// drawn ruler tick marks along the top of the frame
const ticks = Array.from({ length: 41 }, (_, k) => ({ x: +(2 + k * (596 / 40)).toFixed(1), long: k % 5 === 0 }));
type Img = { src: string; label: string };
function pieceImages(piece: { final?: string; rendering?: string; progress?: string[]; swatches?: string[] }): Img[] {
  const out: Img[] = [];
  if (piece.final) out.push({ src: piece.final, label: 'Final' });
  if (piece.rendering) out.push({ src: piece.rendering, label: 'Rendering' });
  (piece.progress ?? []).forEach((s) => out.push({ src: s, label: 'Process' }));
  (piece.swatches ?? []).forEach((s) => out.push({ src: s, label: 'Swatch' }));
  return out;
}
---
<BaseLayout current="costume" title="Costume" description="Costume design by Kaylee Renaud — research, illustration, and construction.">
  <!-- pencil filter: roughens + grains any stroke into a hand-drawn line
       (same language as the About-page doodles) -->
  <svg width="0" height="0" class="kr-defs" aria-hidden="true" focusable="false" style="position:absolute">
    <defs>
      <!-- wobble only (no grain holes) so long structural lines stay continuous -->
      <filter id="kr-rough" x="-15%" y="-15%" width="130%" height="130%">
        <feTurbulence type="fractalNoise" baseFrequency="0.022" numOctaves="2" seed="7" result="w" />
        <feDisplacementMap in="SourceGraphic" in2="w" scale="3.2" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <section class="container page-intro">
    <h1 data-reveal>Costume</h1>
    <p data-reveal style="--d:80ms">Research, illustration, and construction. Each tag is a production — pull one off the rail to see the finished looks alongside the renderings and the work behind them.</p>
  </section>

  <!-- Cork board: costume photos tacked on, each with an oak garment-tag -->
  <section class="container rail-wrap">
    <div class="corkboard">
      <span class="draw-frame" aria-hidden="true"></span>
      <svg class="draw-ruler" viewBox="0 0 600 22" preserveAspectRatio="none" aria-hidden="true" fill="none">
        <line x1="0" y1="3" x2="600" y2="3" />
        {ticks.map((t) => <line x1={t.x} y1="3" x2={t.x} y2={t.long ? 15 : 9} />)}
      </svg>
      <ul class="rack">
        {projects.map((p, i) => (
          <li class="proj-li" data-reveal style={liStyle(i)}>
            <button class="proj-card" data-open={`proj-${p.id}`} aria-haspopup="dialog" aria-label={`Open ${p.show}`}>
              <span class="photo">
                <span class="proj-img"><img src={cover(p)} alt={`${p.show} — costume`} loading="lazy" decoding="async" /></span>
                <span class="tape tape-tl" aria-hidden="true"></span>
                <span class="tape tape-tr" aria-hidden="true"></span>
                <span class="tape tape-bl" aria-hidden="true"></span>
                <span class="tape tape-br" aria-hidden="true"></span>
              </span>
              <span class="card-title">{p.show}</span>
            </button>
          </li>
        ))}
        <li class="proj-li" data-reveal style={liStyle(projects.length)}>
          <button class="proj-card" data-open="proj-upcoming" aria-haspopup="dialog" aria-label="Open Upcoming production">
            <span class="photo">
              <span class="proj-img proj-img-empty"><span class="empty-stamp">Coming Soon</span></span>
              <span class="tape tape-tl" aria-hidden="true"></span>
              <span class="tape tape-tr" aria-hidden="true"></span>
              <span class="tape tape-bl" aria-hidden="true"></span>
              <span class="tape tape-br" aria-hidden="true"></span>
            </span>
            <span class="card-title">{upcoming.show}</span>
          </button>
        </li>
      </ul>
    </div>
    {site.social.instagram && (
      <p class="rack-more" data-reveal>More productions on <a href={site.social.instagram} target="_blank" rel="noopener">Instagram ↗</a></p>
    )}
  </section>

  <!-- PLATE OVERLAYS — one per project, hidden until its tag is opened -->
  {projects.map((p) => (
    <div class="panel" id={`proj-${p.id}`} role="dialog" aria-modal="true" aria-label={p.show}>
      <div class="panel-inner">
        <button class="panel-close" aria-label="Close">×</button>
        <button class="panel-prev" aria-label="Previous project">‹</button>
        <button class="panel-next" aria-label="Next project">›</button>
        <header class="panel-head">
          <p class="ph-kicker stamp">{p.kind === 'paper' ? 'Paper Project' : 'Production'}</p>
          <h2 class="ph-show hand">{p.show}</h2>
          <p class="ph-meta">
            <span class="stamp">Co.</span> <span class="hand">{p.company}</span>
            <span class="dot">·</span> <span class="hand">{p.director}</span>
            <span class="dot">·</span> <span class="stamp">Role</span> <span class="hand">{p.role}</span>
            <span class="dot">·</span> <span class="stamp">{p.year}</span>
          </p>
          {p.blurb && <p class="ph-blurb">{p.blurb}</p>}
        </header>

        <div class="plates">
          {p.pieces.map((piece) => {
            const imgs = pieceImages(piece);
            const main = imgs[0];
            const sides = imgs.slice(1);
            return (
              <article class="plate" data-gallery>
                <button class="plate-main" data-lightbox data-index="0" data-src={main.src} data-alt={piece.caption} data-caption={piece.caption}>
                  <img src={main.src} alt={piece.caption} loading="lazy" decoding="async" />
                  <span class="plate-label stamp">{main.label}</span>
                </button>
                {sides.length > 0 && (
                  <div class="plate-side">
                    {sides.map((im, k) => (
                      <button class="plate-thumb" data-lightbox data-index={k + 1} data-src={im.src} data-alt={piece.caption} data-caption={piece.caption} style={`--r:${(k % 2 ? 1 : -1) * (1.5 + k)}deg`}>
                        <img src={im.src} alt={`${im.label} — ${piece.caption}`} loading="lazy" decoding="async" />
                        <span class="thumb-label stamp">{im.label}</span>
                      </button>
                    ))}
                  </div>
                )}
                <p class="plate-caption">{piece.caption}</p>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  ))}

  <!-- Upcoming overlay — no images yet, kept cohesive -->
  <div class="panel" id="proj-upcoming" role="dialog" aria-modal="true" aria-label={upcoming.show}>
    <div class="panel-inner">
      <button class="panel-close" aria-label="Close">×</button>
      <button class="panel-prev" aria-label="Previous project">‹</button>
      <button class="panel-next" aria-label="Next project">›</button>
      <header class="panel-head">
        <p class="ph-kicker stamp">Upcoming</p>
        <h2 class="ph-show hand">{upcoming.show}</h2>
        <p class="ph-meta">
          <span class="stamp">Co.</span> <span class="hand">{upcoming.company}</span>
          <span class="dot">·</span> <span class="hand">{upcoming.director}</span>
          <span class="dot">·</span> <span class="stamp">Role</span> <span class="hand">{upcoming.role}</span>
          <span class="dot">·</span> <span class="stamp">{upcoming.date}</span>
        </p>
      </header>
      <div class="cs-frame">
        <span class="cs-stamp">Coming Soon</span>
        <p class="cs-note">In development — looks &amp; imagery to be revealed.</p>
        <p class="cs-sub stamp">Check back soon</p>
      </div>
    </div>
  </div>

  <Lightbox />
</BaseLayout>

<style>
  /* ---------- CORK BOARD + PROJECT CARDS ---------- */
  .rail-wrap { position: relative; padding-block: 1rem clamp(3rem, 7vw, 5rem); }

  .corkboard {
    position: relative; border-radius: 4px;
    padding: clamp(3.5rem, 6vw, 5rem) clamp(2rem, 5vw, 3.5rem) clamp(2.5rem, 5vw, 3.5rem);
  }
  /* hand-drawn pencil frame (roughened by #kr-pencil, same as About doodles) */
  .draw-frame {
    position: absolute; inset: 8px; pointer-events: none; z-index: 0;
    border: 2.5px solid var(--sketch-ink, #ece6d8); border-radius: 6px;
    filter: url(#kr-rough); opacity: .82;
  }
  /* drawn ruler — runs the full width of the board (frame edge to frame edge).
     The SVG is a replaced element, so it needs an explicit width to stretch
     (left+right alone fall back to its intrinsic size). */
  .draw-ruler {
    position: absolute; top: 16px; left: 8px; width: calc(100% - 16px); height: 22px;
    display: block; z-index: 0; pointer-events: none;
    color: var(--sketch-ink, #ece6d8); opacity: .82; filter: url(#kr-rough); overflow: visible;
  }
  .draw-ruler line { stroke: currentColor; stroke-width: 2.1; stroke-linecap: round; vector-effect: non-scaling-stroke; }
  @media (max-width: 480px) { .draw-ruler { display: none; } }

  .rack { list-style: none; margin: 0; padding: 0; display: grid; position: relative; z-index: 1;
    grid-template-columns: repeat(3, 1fr); gap: clamp(1.75rem, 3.5vw, 3rem) clamp(1.5rem, 3vw, 2.5rem); }
  @media (max-width: 760px) { .rack { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .rack { grid-template-columns: 1fr; } }
  .proj-li { list-style: none; }

  .proj-card { position: relative; display: block; width: 100%; padding: 0; border: 0; background: none; cursor: pointer;
    transform: rotate(calc((var(--i) % 5 - 2) * 1.1deg)); transition: transform .3s ease; }
  @media (hover: hover) { .proj-card:hover { transform: rotate(0deg); } }
  .proj-card:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .proj-img { display: block; aspect-ratio: 4 / 5; overflow: hidden; border-radius: 4px; box-shadow: 0 14px 30px rgba(0,0,0,.45); }
  .proj-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .45s ease; }
  @media (hover: hover) { .proj-card:hover .proj-img img { transform: scale(1.05); } }
  /* empty tile for the Upcoming card */
  .proj-img-empty { display: flex; align-items: center; justify-content: center;
    background: repeating-linear-gradient(135deg, #16130f 0 12px, #1b1712 12px 24px); }
  .empty-stamp { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .22em; font-size: .78rem;
    color: color-mix(in srgb, var(--accent) 62%, #cfc9c0); border: 2px solid color-mix(in srgb, var(--accent) 50%, var(--line));
    border-radius: 5px; padding: 6px 12px; transform: rotate(-5deg); }

  .photo { position: relative; display: block; }

  /* a little wrinkled cellophane tape on each corner, holding the photo down */
  .tape {
    position: absolute; z-index: 2; width: 62px; height: 26px;
    background-color: rgba(236, 238, 235, 0.13);
    -webkit-backdrop-filter: blur(0.7px) brightness(1.12) contrast(0.97);
    backdrop-filter: blur(0.7px) brightness(1.12) contrast(0.97);
    background-image:
      linear-gradient(var(--shineA, 112deg), transparent calc(var(--s1, 28%) - 13%), rgba(255,255,255,.34) var(--s1, 28%), transparent calc(var(--s1, 28%) + 13%)),
      linear-gradient(var(--shineA, 70deg), transparent calc(var(--s2, 62%) - 9%), rgba(255,255,255,.18) var(--s2, 62%), transparent calc(var(--s2, 62%) + 9%)),
      repeating-linear-gradient(var(--crA, 116deg), rgba(255,255,255,0) 0 5px, rgba(255,255,255,.06) 6px 7px, rgba(255,255,255,0) 8px 13px);
    box-shadow: 0 1px 3px rgba(0,0,0,.3);
    /* torn ends */
    clip-path: polygon(3% 12%, 8% 0, 94% 7%, 100% 0, 97% 90%, 92% 100%, 5% 95%, 0 100%);
  }
  .tape-tl { top: 0; left: 0;  transform: translate(-50%, -50%) rotate(calc(-45deg + var(--jit, 0deg))); }
  .tape-tr { top: 0; right: 0; transform: translate(50%, -50%) rotate(calc(45deg + var(--jit, 0deg))); }
  .tape-bl { bottom: 0; left: 0;  transform: translate(-50%, 50%) rotate(calc(45deg + var(--jit, 0deg))); }
  .tape-br { bottom: 0; right: 0; transform: translate(50%, 50%) rotate(calc(-45deg + var(--jit, 0deg))); }

  /* handwritten title written under each taped photo */
  .card-title {
    display: block; margin-top: 1.1rem; text-align: center; line-height: 1.1;
    font-family: var(--font-hand); font-weight: 700;
    font-size: clamp(1.1rem, 2.6vw, 1.5rem); color: var(--sketch-ink, #ece6d8);
  }

  .stamp { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .1em;
    font-size: .62rem; color: #5a4a2e; opacity: .85; }
  .hand { font-family: var(--font-hand); font-weight: 600; color: #363024; line-height: 1; }
  .rack-more { margin-top: clamp(2rem, 4vw, 3rem); text-align: center; color: var(--ink-soft); }

  /* ---------- PLATE OVERLAY ---------- */
  .panel { position: fixed; inset: 0; z-index: 95; display: none; overflow-y: auto;
    background: color-mix(in srgb, var(--bg) 94%, #000);
    background-image: repeating-linear-gradient(90deg, transparent 0 3px, rgba(255,255,255,.012) 3px 4px),
                      repeating-linear-gradient(0deg, transparent 0 3px, rgba(0,0,0,.04) 3px 4px); }
  .panel.open { display: block; animation: panel-in .32s ease; }
  .panel.open.instant { animation: none; } /* stepping between projects = no fade, no flash */
  @keyframes panel-in { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }
  .panel-inner { max-width: 1080px; margin: 0 auto; padding: clamp(2.5rem, 6vw, 4rem) var(--gap) 5rem; }
  .panel-close {
    position: fixed; top: 1rem; right: 1.1rem; z-index: 2; width: 46px; height: 46px;
    font-size: 1.8rem; line-height: 1; color: var(--ink); background: color-mix(in srgb, var(--accent) 22%, #1c1916);
    border: 1px solid var(--line); border-radius: 50%; cursor: pointer; transition: background .15s, transform .15s;
  }
  @media (hover: hover) { .panel-close:hover { background: var(--accent); color: #14110f; transform: scale(1.06); } }
  /* navigate between projects without leaving the overlay */
  .panel-prev, .panel-next { position: fixed; top: 50%; transform: translateY(-50%); z-index: 2;
    width: 48px; height: 48px; font-size: 2rem; line-height: 1; color: var(--ink);
    background: color-mix(in srgb, var(--accent) 18%, #1c1916); border: 1px solid var(--line);
    border-radius: 50%; cursor: pointer; transition: background .15s, transform .15s; }
  .panel-prev { left: 1rem; } .panel-next { right: 1rem; }
  @media (hover: hover) { .panel-prev:hover, .panel-next:hover { background: var(--accent); color: #14110f; transform: translateY(-50%) scale(1.06); } }
  @media (max-width: 560px) { .panel-prev { left: .4rem; } .panel-next { right: .4rem; } }

  /* Upcoming overlay — no images, kept cohesive */
  .cs-frame { margin-top: 2rem; min-height: 46vh; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 1.1rem; text-align: center;
    border: 2px dashed color-mix(in srgb, var(--accent) 45%, var(--line)); border-radius: 6px;
    padding: clamp(2rem, 6vw, 4rem); }
  .cs-stamp { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .2em; font-size: 1rem;
    color: #b06a6a; border: 2px solid #b06a6a; border-radius: 6px; padding: 6px 14px; transform: rotate(-4deg); opacity: .85; }
  .cs-note { font-family: var(--font-hand); font-size: clamp(1.6rem, 4vw, 2.4rem); color: var(--ink);
    max-width: 24ch; line-height: 1.15; margin: 0; }
  .cs-sub { margin: 0; }

  .panel-head { border-bottom: 2px dashed color-mix(in srgb, var(--accent) 40%, var(--line)); padding-bottom: 1.5rem; margin-bottom: 2.5rem; }
  .ph-kicker { color: var(--accent); }
  .ph-show { font-family: var(--font-hand); font-size: clamp(2.4rem, 7vw, 4rem); line-height: .9; margin: .2rem 0 .6rem; color: var(--ink); }
  .ph-meta { color: var(--ink-soft); font-size: .95rem; display: flex; flex-wrap: wrap; gap: .35rem; align-items: baseline; }
  .ph-meta .hand { font-family: var(--font-hand); font-size: 1.2rem; color: var(--ink); }
  .ph-meta .dot { opacity: .5; }
  .ph-blurb { color: var(--ink-soft); margin: 1rem 0 0; max-width: 60ch; }

  .plates { display: flex; flex-direction: column; gap: clamp(2.5rem, 6vw, 4.5rem); }
  .plate { display: grid; grid-template-columns: minmax(0, 1.65fr) minmax(0, 1fr);
    grid-template-areas: 'main side' 'cap cap'; gap: clamp(1rem, 2.5vw, 1.75rem);
    align-items: center; /* side mini-gallery centers vertically to the final */ }
  @media (max-width: 680px) { .plate { grid-template-columns: 1fr; grid-template-areas: 'main' 'side' 'cap'; } }

  .plate-main { grid-area: main; position: relative; display: block; padding: 0; border: 0; cursor: zoom-in;
    background: none; line-height: 0; }
  .plate-main img { width: 100%; border-radius: 3px; box-shadow: 0 14px 36px rgba(0,0,0,.5);
    border: 6px solid #efe9dc; }
  /* the renderings/progress: compact, never taller than the final, centered to it */
  .plate-side { grid-area: side; display: flex; flex-direction: column; justify-content: center;
    gap: clamp(.9rem, 2vw, 1.4rem); }
  .plate-thumb { position: relative; display: block; padding: 0; border: 0; cursor: zoom-in; background: none; line-height: 0;
    transform: rotate(var(--r, -2deg)); transition: transform .2s; }
  @media (hover: hover) { .plate-thumb:hover { transform: rotate(0) scale(1.02); } }
  .plate-thumb img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover;
    border-radius: 2px; border: 5px solid #efe9dc; box-shadow: 0 8px 20px rgba(0,0,0,.45); }
  @media (max-width: 680px) {
    .plate-side { flex-direction: row; flex-wrap: wrap; justify-content: flex-start; }
    .plate-thumb { width: calc(50% - .7rem); }
  }
  /* a little "tape" at the top of each pinned thumb */
  .plate-thumb::before { content: ''; position: absolute; top: -9px; left: 50%; transform: translateX(-50%) rotate(-3deg);
    width: 46px; height: 16px; background: color-mix(in srgb, var(--accent) 30%, #d8d2c4); opacity: .55; border-radius: 1px; }

  .plate-label, .thumb-label { position: absolute; left: 8px; bottom: 8px;
    background: rgba(20,16,18,.7); color: #f3efe9; padding: 2px 7px; border-radius: 3px; line-height: 1.4; }
  .thumb-label { font-size: .56rem; }

  .plate-caption { grid-area: cap; color: var(--ink-soft); font-size: 1rem; line-height: 1.6; max-width: 70ch;
    border-left: 2px solid color-mix(in srgb, var(--accent) 50%, var(--line)); padding-left: 1rem; }

  @media (prefers-reduced-motion: reduce) {
    .oaktag, .plate-thumb { transition: none; }
    .oaktag:hover { animation: none; }
    .panel.open { animation: none; }
  }
</style>

<script>
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.panel'));
  let openEl: HTMLElement | null = null;
  const lbUp = () => !!document.querySelector('#lightbox[open]');

  function show(p: HTMLElement, instant = false) {
    if (openEl && openEl !== p) openEl.classList.remove('open', 'instant');
    openEl = p;
    p.classList.toggle('instant', instant);   // skip the fade when stepping between projects
    p.classList.add('open');
    p.scrollTop = 0;
    document.body.style.overflow = 'hidden';
  }
  function close() {
    if (!openEl) return;
    openEl.classList.remove('open', 'instant');
    openEl = null;
    document.body.style.overflow = '';
  }
  function navigate(dir: number) {
    if (!openEl) return;
    const i = panels.indexOf(openEl);
    show(panels[(i + dir + panels.length) % panels.length], true);
  }

  document.querySelectorAll<HTMLElement>('[data-open]').forEach((btn) =>
    btn.addEventListener('click', () => { const p = document.getElementById(btn.dataset.open!); if (p) show(p, false); })
  );
  panels.forEach((p) => {
    p.querySelector('.panel-close')?.addEventListener('click', close);
    p.querySelector('.panel-prev')?.addEventListener('click', () => navigate(-1));
    p.querySelector('.panel-next')?.addEventListener('click', () => navigate(1));
    // click the backdrop (outside the inner column) to close
    p.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('.panel-inner')) close();
    });
  });
  document.addEventListener('keydown', (e) => {
    if (!openEl || lbUp()) return;           // let the image lightbox own keys while it's up
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') navigate(-1);
    else if (e.key === 'ArrowRight') navigate(1);
  });
</script>
